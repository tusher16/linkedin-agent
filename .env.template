# LinkedIn Agent — Environment Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. This template must contain placeholders only.

# ── LLM Providers ────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── LangSmith Tracing ────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=linkedin-agent
LANGCHAIN_API_KEY=your-langsmith-api-key-here

# ── LinkedIn Publishing ───────────────────────────────────────────────────────
POSTBOOST_API_KEY=your-postboost-api-key-here

# ── Database (added Day 3) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/linkedin_agent

# ── FastAPI Auth (added Day 6) ────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# ── Backblaze B2 Backup (added Day 10) ───────────────────────────────────────
B2_ACCESS_KEY_ID=your-b2-key-id-here
B2_SECRET_ACCESS_KEY=your-b2-secret-here
